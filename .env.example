# ============================================
# SmartCharge Environment Variables
# ============================================
# Copy this file to .env and fill in the values
# ============================================

# --- Next.js Frontend ---
# URL of the Go API backend (used in next.config.ts rewrites)
# Local: http://localhost:8080
# Railway: https://your-api-service.up.railway.app
API_URL="http://localhost:8080"

# --- Go API Backend (set in docker-compose.yml for local, Railway dashboard for prod) ---

# PostgreSQL connection string
# Local: postgres://admin:admin@db:5432/evcharge?sslmode=disable
# Railway: provided automatically by Railway Postgres plugin ($DATABASE_URL)
# DATABASE_URL="postgres://admin:admin@localhost:5432/evcharge?sslmode=disable"

# JWT signing secret -- MUST be set in production (API panics if empty in GIN_MODE=release)
# Use a strong random string (32+ chars) in production
# JWT_SECRET="your-secret-key-here"

# Server port (Railway sets $PORT automatically)
# PORT="8080"

# Gin mode: "debug" for development, "release" for production
# GIN_MODE="debug"

# Frontend URL for CORS (set to your Railway frontend URL in production)
# FRONTEND_URL="http://localhost:3000"

# --- Optional: AI/LLM (for chatbot, Phase 7) ---
# LLM_URL="http://localhost:11434"
# LLM_MODEL="llama3.2"
